{% if adapter.timer.backend == "azure_service_bus" %}
from azure.servicebus.aio import ServiceBusClient
from azure.servicebus import ServiceBusMessage


class {{ adapter.class_name }}(ITimerService):
    """
    {{ adapter.display_name }}.

    Uses Azure Service Bus scheduled messages (scheduled_enqueue_time_utc).
    Guaranteed delivery — no polling process required. The broker holds the
    message and delivers it exactly once at the scheduled time.

    Cancel by sequence number before the enqueue time; after enqueue the
    message is already in the active queue and cannot be recalled.

    Required env vars:
      {{ adapter.timer.azure_service_bus.env_var_connection_string | default('AZURE_SERVICEBUS_CONN_STR') }}
    """

    def __init__(
        self,
        connection_string: str | None = None,
        default_topic: str = "{{ adapter.timer.azure_service_bus.default_topic | default('awa-agent-cortex-timers') }}",
    ) -> None:
        self._connection_string = connection_string or os.environ[
            "{{ adapter.timer.azure_service_bus.env_var_connection_string | default('AZURE_SERVICEBUS_CONN_STR') }}"
        ]
        self._default_topic = default_topic

    async def schedule(
        self,
        delay_seconds: int,
        event: BaseEvent,
        topic: str | None = None,
    ) -> ScheduledTimer:
        deliver_at = datetime.now(timezone.utc) + timedelta(seconds=delay_seconds)
        target_topic = topic or self._default_topic

        body = json.dumps(event.__dict__, default=str)
        message = ServiceBusMessage(
            body,
            content_type="application/json",
            subject=event.event_type,
            scheduled_enqueue_time_utc=deliver_at,
        )

        async with ServiceBusClient.from_connection_string(self._connection_string) as client:
            sender = client.get_topic_sender(topic_name=target_topic)
            async with sender:
                seq_numbers = await sender.schedule_messages(message, deliver_at)
                timer_id = str(seq_numbers[0])

        logger.info(
            "Timer scheduled: event_type=%s topic=%s deliver_at=%s seq=%s",
            event.event_type, target_topic, deliver_at.isoformat(), timer_id,
        )
        return ScheduledTimer(timer_id=timer_id, topic=target_topic, deliver_at_utc=deliver_at)

    async def cancel(self, timer_id: str) -> bool:
        try:
            async with ServiceBusClient.from_connection_string(self._connection_string) as client:
                sender = client.get_topic_sender(topic_name=self._default_topic)
                async with sender:
                    await sender.cancel_scheduled_messages(int(timer_id))
            logger.info("Timer cancelled: seq=%s", timer_id)
            return True
        except Exception as exc:
            logger.warning("Timer cancel failed (may have already fired): seq=%s err=%s", timer_id, exc)
            return False

    @property
    def backend_name(self) -> str:
        return "azure_service_bus"


{% elif adapter.timer.backend == "aws_eventbridge" %}
import uuid
import boto3


class {{ adapter.class_name }}(ITimerService):
    """
    {{ adapter.display_name }}.

    Uses AWS EventBridge Scheduler one-time schedules.
    Each call creates a schedule that fires once and self-deletes
    (ActionAfterCompletion="DELETE"). The target receives the event payload
    as a JSON string — target must be an SQS queue, SNS topic, or Lambda.

    Required env vars:
      {{ adapter.timer.aws_eventbridge.env_var_target_arn | default('EVENTBRIDGE_TARGET_ARN') }}
      {{ adapter.timer.aws_eventbridge.env_var_role_arn | default('EVENTBRIDGE_SCHEDULER_ROLE_ARN') }}
      {{ adapter.timer.aws_eventbridge.env_var_region | default('AWS_REGION') }}
    """

    _SCHEDULE_GROUP = "{{ adapter.timer.aws_eventbridge.schedule_group | default('awa-agent-cortex') }}"

    def __init__(
        self,
        target_arn: str | None = None,
        role_arn: str | None = None,
        region: str | None = None,
    ) -> None:
        self._target_arn = target_arn or os.environ[
            "{{ adapter.timer.aws_eventbridge.env_var_target_arn | default('EVENTBRIDGE_TARGET_ARN') }}"
        ]
        self._role_arn = role_arn or os.environ[
            "{{ adapter.timer.aws_eventbridge.env_var_role_arn | default('EVENTBRIDGE_SCHEDULER_ROLE_ARN') }}"
        ]
        _region = region or os.environ.get(
            "{{ adapter.timer.aws_eventbridge.env_var_region | default('AWS_REGION') }}", "us-east-1"
        )
        self._scheduler = boto3.client("scheduler", region_name=_region)
        logger.info("EventBridgeTimer: target_arn=%s group=%s", self._target_arn, self._SCHEDULE_GROUP)

    async def schedule(
        self,
        delay_seconds: int,
        event: BaseEvent,
        topic: str | None = None,
    ) -> ScheduledTimer:
        deliver_at = datetime.now(timezone.utc) + timedelta(seconds=delay_seconds)
        # AT expression requires UTC, no microseconds
        at_expr = f"at({deliver_at.strftime('%Y-%m-%dT%H:%M:%S')})"
        schedule_name = f"awa-{event.event_type.lower().replace('_', '-')}-{uuid.uuid4().hex[:10]}"

        payload = json.dumps({**event.__dict__, "_topic": topic or ""}, default=str)

        self._scheduler.create_schedule(
            Name=schedule_name,
            GroupName=self._SCHEDULE_GROUP,
            ScheduleExpression=at_expr,
            ScheduleExpressionTimezone="UTC",
            FlexibleTimeWindow={"Mode": "OFF"},
            ActionAfterCompletion="DELETE",
            Target={
                "Arn":     self._target_arn,
                "RoleArn": self._role_arn,
                "Input":   payload,
            },
        )

        logger.info(
            "Timer scheduled: event_type=%s schedule=%s deliver_at=%s",
            event.event_type, schedule_name, deliver_at.isoformat(),
        )
        return ScheduledTimer(timer_id=schedule_name, topic=topic or "", deliver_at_utc=deliver_at)

    async def cancel(self, timer_id: str) -> bool:
        try:
            self._scheduler.delete_schedule(Name=timer_id, GroupName=self._SCHEDULE_GROUP)
            logger.info("Timer cancelled: schedule=%s", timer_id)
            return True
        except self._scheduler.exceptions.ResourceNotFoundException:
            # Already fired and self-deleted — not an error
            logger.debug("Timer already fired or not found: schedule=%s", timer_id)
            return False
        except Exception as exc:
            logger.warning("Timer cancel error: schedule=%s err=%s", timer_id, exc)
            return False

    @property
    def backend_name(self) -> str:
        return "aws_eventbridge_scheduler"


{% elif adapter.timer.backend == "celery_beat" %}
class {{ adapter.class_name }}(ITimerService):
    """
    {{ adapter.display_name }}.

    Uses Celery's apply_async(countdown=N) to delay task execution.
    The Celery worker calls deliver_timer_event, which publishes the
    BaseEvent to the configured event bus.

    Operational requirements:
      • A Celery worker pod consuming the timer queue must be running.
      • The broker (Redis or RabbitMQ) must be reachable.
      • The task awa_agent_cortex.tasks.deliver_timer_event must be registered.

    Required env vars:
      {{ adapter.timer.celery_beat.env_var_broker_url | default('CELERY_BROKER_URL') }}
      {{ adapter.timer.celery_beat.env_var_result_backend | default('CELERY_RESULT_BACKEND') }}  (optional)

    cancel() uses Celery's revoke() — the task is cancelled if not yet started.
    There is no guarantee of cancellation if the worker has already picked it up.
    """

    def __init__(self, app: "Celery | None" = None) -> None:
        if app is None:
            from celery import Celery
            broker_url = os.environ[
                "{{ adapter.timer.celery_beat.env_var_broker_url | default('CELERY_BROKER_URL') }}"
            ]
            result_backend = os.getenv(
                "{{ adapter.timer.celery_beat.env_var_result_backend | default('CELERY_RESULT_BACKEND') }}"
            )
            app = Celery(
                "awa_agent_cortex_timers",
                broker=broker_url,
                backend=result_backend,
            )
        self._app = app
        logger.info("CeleryBeatTimer: broker=%s", self._app.conf.broker_url)

    async def schedule(
        self,
        delay_seconds: int,
        event: BaseEvent,
        topic: str | None = None,
    ) -> ScheduledTimer:
        deliver_at = datetime.now(timezone.utc) + timedelta(seconds=delay_seconds)
        result = self._app.send_task(
            "awa_agent_cortex.tasks.deliver_timer_event",
            kwargs={
                "event_dict": event.__dict__,
                "topic":      topic or "",
            },
            countdown=delay_seconds,
            serializer="json",
        )
        logger.info(
            "Timer scheduled: event_type=%s task_id=%s deliver_at=%s",
            event.event_type, result.id, deliver_at.isoformat(),
        )
        return ScheduledTimer(timer_id=result.id, topic=topic or "", deliver_at_utc=deliver_at)

    async def cancel(self, timer_id: str) -> bool:
        try:
            self._app.control.revoke(timer_id, terminate=False)
            logger.info("Timer revoked: task_id=%s", timer_id)
            return True
        except Exception as exc:
            logger.warning("Timer revoke failed: task_id=%s err=%s", timer_id, exc)
            return False

    @property
    def backend_name(self) -> str:
        return "celery_beat"

{% endif %}
