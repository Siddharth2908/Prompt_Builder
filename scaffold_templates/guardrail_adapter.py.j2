from __future__ import annotations

import logging
import os
from abc import ABC, abstractmethod
from dataclasses import dataclass, field
from enum import Enum

logger = logging.getLogger(__name__)

# ── Port types (reproduced here for reference; canonical copy lives in ports/) ─

class ScanVerdict(str, Enum):
    PASS  = "pass"   # Content is clean; build continues
    WARN  = "warn"   # Service degraded; build continues, alert emitted
    BLOCK = "block"  # Content rejected; build aborts with SAFETY_VIOLATION


@dataclass
class GuardrailResult:
    verdict:    ScanVerdict
    confidence: float            # 0.0–1.0
    reason:     str | None       # Human-readable; included in audit log
    categories: list[str]        # e.g. ["prompt_injection", "hate"]
    provider:   str              # adapter.provider_name


class IGuardrailService(ABC):
    """Scans content for injection attempts and policy violations."""

    @abstractmethod
    async def scan(
        self,
        content: str,
        consumer_id: str,
        job_id: str,
    ) -> GuardrailResult:
        """
        Scan content and return a verdict.
        Must NEVER raise — on service failure return ScanVerdict.WARN so the
        in-process pattern layer remains the last line before a build continues.
        """
        ...

    @property
    @abstractmethod
    def provider_name(self) -> str:
        ...

    async def close(self) -> None:
        """Release SDK clients on shutdown."""


# ── Implementation ────────────────────────────────────────────────────────────

{% if adapter.guardrail.provider == "azure_content_safety" %}
from azure.ai.contentsafety.aio import ContentSafetyClient
from azure.ai.contentsafety.models import (
    AnalyzeTextOptions,
    ShieldPromptOptions,
    TextCategory,
)
from azure.core.credentials import AzureKeyCredential


class {{ adapter.class_name }}(IGuardrailService):
    """
    {{ adapter.display_name }}.

    Two-layer scan:
      Layer 1 — Prompt Shield: detects direct and indirect prompt injection.
                Uses userPromptAnalysis; attackDetected=true → BLOCK.
      Layer 2 — Content Filter: Hate, Violence, Sexual, SelfHarm categories.
                Severity ≥ 4 (on 0–6 scale) → BLOCK.

    Auth: Managed Identity (preferred on AKS) or API key via env var.
    Required env vars:
      {{ adapter.guardrail.azure_content_safety.env_var_endpoint | default('AZURE_CONTENT_SAFETY_ENDPOINT') }}
      {{ adapter.guardrail.azure_content_safety.env_var_api_key | default('AZURE_CONTENT_SAFETY_KEY') }}
        (optional — omit to use Managed Identity)
    """

    _SEVERITY_BLOCK_THRESHOLD = {{ adapter.guardrail.azure_content_safety.severity_threshold | default(4) }}

    def __init__(self) -> None:
        endpoint = os.environ[
            "{{ adapter.guardrail.azure_content_safety.env_var_endpoint | default('AZURE_CONTENT_SAFETY_ENDPOINT') }}"
        ]
        api_key = os.getenv(
            "{{ adapter.guardrail.azure_content_safety.env_var_api_key | default('AZURE_CONTENT_SAFETY_KEY') }}"
        )
        if api_key:
            credential = AzureKeyCredential(api_key)
            logger.info("AzureContentSafety: using API key auth")
        else:
            from azure.identity.aio import DefaultAzureCredential
            credential = DefaultAzureCredential()
            logger.info("AzureContentSafety: using DefaultAzureCredential (Managed Identity)")
        self._client = ContentSafetyClient(endpoint, credential)

    async def scan(self, content: str, consumer_id: str, job_id: str) -> GuardrailResult:
        # Layer 1: Prompt Shield
        try:
            shield = await self._client.shield_prompt(
                ShieldPromptOptions(user_prompt=content)
            )
            if (
                shield.user_prompt_analysis
                and shield.user_prompt_analysis.attack_detected
            ):
                logger.warning(
                    "GUARDRAIL BLOCK prompt_injection consumer=%s job=%s provider=%s",
                    consumer_id, job_id, self.provider_name,
                )
                return GuardrailResult(
                    verdict=ScanVerdict.BLOCK,
                    confidence=0.95,
                    reason="Prompt injection detected by Azure Prompt Shield",
                    categories=["prompt_injection"],
                    provider=self.provider_name,
                )
        except Exception as exc:
            logger.warning("Prompt Shield unavailable: %s — falling through to content filter", exc)

        # Layer 2: Content filter
        try:
            result = await self._client.analyze_text(
                AnalyzeTextOptions(
                    text=content,
                    categories=[
                        TextCategory.HATE,
                        TextCategory.VIOLENCE,
                        TextCategory.SEXUAL,
                        TextCategory.SELF_HARM,
                    ],
                )
            )
            blocked = [
                cat.category
                for cat in (result.categories_analysis or [])
                if cat.severity is not None and cat.severity >= self._SEVERITY_BLOCK_THRESHOLD
            ]
            if blocked:
                logger.warning(
                    "GUARDRAIL BLOCK harmful_content categories=%s consumer=%s job=%s",
                    blocked, consumer_id, job_id,
                )
                return GuardrailResult(
                    verdict=ScanVerdict.BLOCK,
                    confidence=0.90,
                    reason=f"Harmful content categories: {', '.join(blocked)}",
                    categories=blocked,
                    provider=self.provider_name,
                )
        except Exception as exc:
            logger.warning(
                "Content Safety analyze_text unavailable: %s — emitting WARN, build continues", exc
            )
            return GuardrailResult(
                verdict=ScanVerdict.WARN,
                confidence=0.0,
                reason=f"Azure Content Safety unavailable: {exc}",
                categories=[],
                provider=self.provider_name,
            )

        return GuardrailResult(
            verdict=ScanVerdict.PASS,
            confidence=1.0,
            reason=None,
            categories=[],
            provider=self.provider_name,
        )

    @property
    def provider_name(self) -> str:
        return "azure_content_safety"

    async def close(self) -> None:
        await self._client.close()


{% elif adapter.guardrail.provider == "amazon_comprehend" %}
import boto3


class {{ adapter.class_name }}(IGuardrailService):
    """
    {{ adapter.display_name }}.

    Two-layer scan:
      Layer 1 — AWS Bedrock Guardrails (optional): full content policy including
                topic denial, word filters, and grounding checks.
                Skipped if BEDROCK_GUARDRAIL_ID is not set.
      Layer 2 — Amazon Comprehend detect_toxic_content: toxicity labels.
                Score ≥ {{ adapter.guardrail.amazon_comprehend.toxicity_threshold | default(0.80) }} → BLOCK.

    NOTE: No native prompt injection classifier equivalent to Azure Prompt Shield
    exists on AWS. The in-process PatternMatcher is the primary injection guard
    in this deployment profile. Consider the local_model adapter for deeper coverage.

    Required env vars:
      {{ adapter.guardrail.amazon_comprehend.env_var_region | default('AWS_REGION') }}
      BEDROCK_GUARDRAIL_ID      (optional — enables Bedrock Guardrails layer)
      BEDROCK_GUARDRAIL_VERSION (optional — defaults to DRAFT)
    """

    _TOXICITY_THRESHOLD: float = {{ adapter.guardrail.amazon_comprehend.toxicity_threshold | default(0.80) }}
    _COMPREHEND_MAX_CHARS:  int = 4096  # Comprehend hard limit

    def __init__(self) -> None:
        region = os.environ.get(
            "{{ adapter.guardrail.amazon_comprehend.env_var_region | default('AWS_REGION') }}", "us-east-1"
        )
        session = boto3.Session(region_name=region)
        self._comprehend = session.client("comprehend")
        guardrail_id = os.getenv("BEDROCK_GUARDRAIL_ID")
        if guardrail_id:
            self._bedrock = session.client("bedrock-runtime")
            self._guardrail_id = guardrail_id
            self._guardrail_version = os.getenv("BEDROCK_GUARDRAIL_VERSION", "DRAFT")
            logger.info("AmazonComprehendGuardrail: Bedrock Guardrails enabled id=%s", guardrail_id)
        else:
            self._bedrock = None
            self._guardrail_id = None
            self._guardrail_version = None
            logger.info("AmazonComprehendGuardrail: Bedrock Guardrails not configured; Comprehend only")

    async def scan(self, content: str, consumer_id: str, job_id: str) -> GuardrailResult:
        # Layer 1: Bedrock Guardrails (optional)
        if self._bedrock and self._guardrail_id:
            try:
                response = self._bedrock.apply_guardrail(
                    guardrailIdentifier=self._guardrail_id,
                    guardrailVersion=self._guardrail_version,
                    source="INPUT",
                    content=[{"text": {"text": content}}],
                )
                if response.get("action") == "GUARDRAIL_INTERVENED":
                    blocked_topics = [
                        o.get("topic", {}).get("name", "unknown")
                        for o in response.get("outputs", [])
                        if "topic" in o
                    ]
                    logger.warning(
                        "GUARDRAIL BLOCK bedrock_guardrail topics=%s consumer=%s job=%s",
                        blocked_topics, consumer_id, job_id,
                    )
                    return GuardrailResult(
                        verdict=ScanVerdict.BLOCK,
                        confidence=0.90,
                        reason=f"Bedrock Guardrail intervened: {', '.join(blocked_topics)}",
                        categories=blocked_topics or ["policy_violation"],
                        provider=self.provider_name,
                    )
            except Exception as exc:
                logger.warning("Bedrock Guardrail unavailable: %s — falling through to Comprehend", exc)

        # Layer 2: Amazon Comprehend toxicity
        try:
            text_segment = content[:self._COMPREHEND_MAX_CHARS]
            response = self._comprehend.detect_toxic_content(
                TextSegments=[{"Text": text_segment}],
                LanguageCode="en",
            )
            toxic_labels = [
                label["Name"]
                for result in response.get("ResultList", [])
                for label in result.get("Labels", [])
                if label.get("Score", 0.0) >= self._TOXICITY_THRESHOLD
            ]
            if toxic_labels:
                logger.warning(
                    "GUARDRAIL BLOCK toxic_content labels=%s consumer=%s job=%s",
                    toxic_labels, consumer_id, job_id,
                )
                return GuardrailResult(
                    verdict=ScanVerdict.BLOCK,
                    confidence=self._TOXICITY_THRESHOLD,
                    reason=f"Toxic content: {', '.join(toxic_labels)}",
                    categories=toxic_labels,
                    provider=self.provider_name,
                )
        except Exception as exc:
            logger.warning(
                "Comprehend unavailable: %s — emitting WARN, build continues", exc
            )
            return GuardrailResult(
                verdict=ScanVerdict.WARN,
                confidence=0.0,
                reason=f"Amazon Comprehend unavailable: {exc}",
                categories=[],
                provider=self.provider_name,
            )

        return GuardrailResult(
            verdict=ScanVerdict.PASS,
            confidence=1.0,
            reason=None,
            categories=[],
            provider=self.provider_name,
        )

    @property
    def provider_name(self) -> str:
        return "amazon_comprehend"


{% elif adapter.guardrail.provider == "local_model" %}
import httpx


class {{ adapter.class_name }}(IGuardrailService):
    """
    {{ adapter.display_name }}.

    Calls a self-hosted HTTP inference endpoint that returns a classification
    result. Designed for on-prem / air-gapped deployments with no cloud AI
    service access.

    Recommended model: protectai/deberta-v3-base-prompt-injection
    Serving options: vLLM, Hugging Face TGI, BentoML, Triton

    Expected endpoint contract (POST {{ adapter.guardrail.local_model.classify_path | default('/classify') }}):
      Request:  {"text": "<content to scan>"}
      Response: {"label": "INJECTION" | "SAFE", "score": 0.0–1.0}

    If the endpoint is unreachable, returns WARN — never raises.
    The in-process PatternMatcher remains the last guard in this profile.

    Required env vars:
      {{ adapter.guardrail.local_model.env_var_endpoint_url | default('GUARDRAIL_MODEL_ENDPOINT') }}
        e.g. http://guardrail-service.awa-system.svc.cluster.local:8080
    """

    _INJECTION_LABEL   = "INJECTION"
    _CLASSIFY_PATH     = "{{ adapter.guardrail.local_model.classify_path | default('/classify') }}"
    _THRESHOLD: float  = {{ adapter.guardrail.local_model.injection_threshold | default(0.80) }}
    _TIMEOUT_S: int    = {{ adapter.guardrail.local_model.timeout_seconds | default(5) }}

    def __init__(self, endpoint_url: str | None = None) -> None:
        _url = endpoint_url or os.environ[
            "{{ adapter.guardrail.local_model.env_var_endpoint_url | default('GUARDRAIL_MODEL_ENDPOINT') }}"
        ]
        self._endpoint = _url.rstrip("/")
        self._client = httpx.AsyncClient(timeout=httpx.Timeout(self._TIMEOUT_S))
        logger.info("LocalModelGuardrail: endpoint=%s threshold=%.2f", self._endpoint, self._THRESHOLD)

    async def scan(self, content: str, consumer_id: str, job_id: str) -> GuardrailResult:
        try:
            response = await self._client.post(
                f"{self._endpoint}{self._CLASSIFY_PATH}",
                json={"text": content},
            )
            response.raise_for_status()
            result   = response.json()
            label: str   = result.get("label", "SAFE").upper()
            score: float = float(result.get("score", 0.0))

            if label == self._INJECTION_LABEL and score >= self._THRESHOLD:
                logger.warning(
                    "GUARDRAIL BLOCK prompt_injection score=%.3f consumer=%s job=%s",
                    score, consumer_id, job_id,
                )
                return GuardrailResult(
                    verdict=ScanVerdict.BLOCK,
                    confidence=score,
                    reason=f"Prompt injection detected by local model (score={score:.3f})",
                    categories=["prompt_injection"],
                    provider=self.provider_name,
                )

            return GuardrailResult(
                verdict=ScanVerdict.PASS,
                confidence=1.0 - score,
                reason=None,
                categories=[],
                provider=self.provider_name,
            )

        except httpx.TimeoutException as exc:
            logger.warning("LocalModelGuardrail: timeout after %ss — WARN, build continues", self._TIMEOUT_S)
            return GuardrailResult(
                verdict=ScanVerdict.WARN,
                confidence=0.0,
                reason=f"Guardrail service timeout: {exc}",
                categories=[],
                provider=self.provider_name,
            )
        except Exception as exc:
            logger.warning("LocalModelGuardrail: unreachable — WARN, build continues: %s", exc)
            return GuardrailResult(
                verdict=ScanVerdict.WARN,
                confidence=0.0,
                reason=f"Guardrail service unavailable: {exc}",
                categories=[],
                provider=self.provider_name,
            )

    @property
    def provider_name(self) -> str:
        return "local_model"

    async def close(self) -> None:
        await self._client.aclose()

{% endif %}
