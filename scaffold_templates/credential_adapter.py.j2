class ICredentialProvider(ABC):
    """Provides bearer tokens and secret values to infrastructure adapters."""

    @abstractmethod
    async def get_bearer_token(self, scope: str) -> str:
        """Return a Bearer token valid for the given scope/audience."""
        ...

    @abstractmethod
    async def get_secret(self, secret_name: str) -> str:
        """Return the plaintext value of a named secret."""
        ...

    @property
    @abstractmethod
    def provider_name(self) -> str:
        """Short identifier used in logs and metrics."""
        ...

    async def close(self) -> None:
        """Optional: release underlying SDK clients. Called on service shutdown."""


