from azure.identity.aio import DefaultAzureCredential, ManagedIdentityCredential


class {{ adapter.class_name }}(ICredentialProvider):
    """
    {{ adapter.display_name }}.

    Authenticates via AKS Workload Identity (federated Azure AD credential).
    Zero secrets to manage — the kubelet projects a signed OIDC token that Azure
    AD exchanges for a Managed Identity token at runtime.

    Scopes (examples):
      "https://cognitiveservices.azure.com/.default"  — Azure OpenAI
      "https://vault.azure.net/.default"              — Key Vault
      "https://servicebus.azure.net/.default"         — Service Bus

    Set CLIENT_ID env var to target a specific User-Assigned Managed Identity.
    Leave unset to use the System-Assigned identity.
    """

    def __init__(self, client_id: str | None = None) -> None:
        _client_id = client_id or os.getenv("{{ adapter.credential.env_var_client_id | default('AZURE_CLIENT_ID') }}")
        if _client_id:
            self._credential = ManagedIdentityCredential(client_id=_client_id)
            logger.info("AzureManagedIdentity: using user-assigned identity client_id=%s", _client_id)
        else:
            self._credential = DefaultAzureCredential()
            logger.info("AzureManagedIdentity: using DefaultAzureCredential (system-assigned or ambient)")

    async def get_bearer_token(self, scope: str) -> str:
        token = await self._credential.get_token(scope)
        logger.debug("AzureManagedIdentity: obtained token for scope=%s expires_on=%s", scope, token.expires_on)
        return token.token

    async def get_secret(self, secret_name: str) -> str:
        """
        Retrieve a secret from Azure Key Vault.

        Requires the pod's Managed Identity to have Key Vault Secrets User role.
        Construct the vault URI from AZURE_KEYVAULT_URI env var.
        """
        from azure.keyvault.secrets.aio import SecretClient
        vault_uri = os.environ["{{ adapter.credential.env_var_vault_uri | default('AZURE_KEYVAULT_URI') }}"]
        async with SecretClient(vault_url=vault_uri, credential=self._credential) as kv:
            secret = await kv.get_secret(secret_name)
            return secret.value or ""

    @property
    def provider_name(self) -> str:
        return "azure_managed_identity"

    async def close(self) -> None:
        await self._credential.close()


{% elif adapter.credential.provider == "aws_irsa" %}
import boto3
import botocore.credentials


class {{ adapter.class_name }}(ICredentialProvider):
    """
    {{ adapter.display_name }}.

    Authenticates via IAM Roles for Service Accounts (IRSA) on Amazon EKS.
    The pod's service account must be annotated with:
      eks.amazonaws.com/role-arn: arn:aws:iam::<ACCOUNT>:role/<ROLE>

    The kubelet mounts a projected OIDC token at AWS_WEB_IDENTITY_TOKEN_FILE.
    boto3 picks it up automatically via the default credential chain.

    For Bearer-token-based services (not AWS-native), this adapter cannot
    produce OAuth2 tokens — use get_session() to obtain a boto3 Session with
    STS-refreshed credentials, then call the AWS SDK directly.
    """

    def __init__(self, region: str | None = None) -> None:
        self._region = region or os.getenv(
            "{{ adapter.credential.env_var_region | default('AWS_REGION') }}", "us-east-1"
        )
        self._session = boto3.Session(region_name=self._region)
        logger.info("AWSIRSACredential: boto3 session initialised region=%s", self._region)

    def get_session(self) -> boto3.Session:
        """Return a boto3 Session pre-configured with IRSA credentials."""
        return self._session

    async def get_bearer_token(self, scope: str) -> str:
        """
        Not natively supported for AWS services — they use SigV4 signing.
        For cross-cloud scenarios, generate a pre-signed URL or use AWS STS
        federation. Raise NotImplementedError to make the gap explicit.
        """
        raise NotImplementedError(
            "AWS IRSA does not produce OAuth2 Bearer tokens. "
            "Use get_session() to obtain a configured boto3.Session and "
            "call AWS SDK methods directly (SigV4 auth is handled internally)."
        )

    async def get_secret(self, secret_name: str) -> str:
        """Retrieve a secret from AWS Secrets Manager."""
        client = self._session.client("secretsmanager", region_name=self._region)
        try:
            response = client.get_secret_value(SecretId=secret_name)
            return response.get("SecretString") or ""
        except client.exceptions.ResourceNotFoundException:
            logger.error("AWSIRSACredential: secret not found name=%s", secret_name)
            raise

    @property
    def provider_name(self) -> str:
        return "aws_irsa"


{% elif adapter.credential.provider == "vault" %}
import hvac


class {{ adapter.class_name }}(ICredentialProvider):
    """
    {{ adapter.display_name }}.

    Authenticates via HashiCorp Vault's Kubernetes auth method.
    The pod's projected service account token (/var/run/secrets/kubernetes.io/serviceaccount/token)
    is exchanged for a Vault token scoped to the configured role's policies.

    Supports:
      • KV v2 static secrets
      • Dynamic secrets (database credentials, cloud IAM credentials via Vault plugins)
      • Token renewal (auto-renew before TTL expiry)

    Required env vars:
      {{ adapter.credential.env_var_vault_addr | default('VAULT_ADDR') }}     — e.g. https://vault.internal:8200
      {{ adapter.credential.env_var_vault_role | default('VAULT_ROLE') }}     — Vault Kubernetes auth role name
      {{ adapter.credential.env_var_vault_mount | default('VAULT_K8S_MOUNT') }} — Kubernetes auth mount path (default: kubernetes)
    """

    _SA_TOKEN_PATH = "/var/run/secrets/kubernetes.io/serviceaccount/token"

    def __init__(self) -> None:
        vault_addr = os.environ["{{ adapter.credential.env_var_vault_addr | default('VAULT_ADDR') }}"]
        self._role   = os.environ["{{ adapter.credential.env_var_vault_role | default('VAULT_ROLE') }}"]
        self._mount  = os.getenv("{{ adapter.credential.env_var_vault_mount | default('VAULT_K8S_MOUNT') }}", "kubernetes")
        self._client = hvac.Client(url=vault_addr)
        self._kv_mount = "{{ adapter.credential.kv_mount | default('secret') }}"
        self._authenticate()
        logger.info("VaultCredential: authenticated addr=%s role=%s", vault_addr, self._role)

    def _authenticate(self) -> None:
        with open(self._SA_TOKEN_PATH) as f:
            sa_jwt = f.read()
        self._client.auth.kubernetes.login(
            role=self._role,
            jwt=sa_jwt,
            mount_point=self._mount,
        )
        if not self._client.is_authenticated():
            raise RuntimeError("Vault Kubernetes auth failed — check role binding and policies")

    async def get_bearer_token(self, scope: str) -> str:
        """
        Vault does not issue OAuth2 Bearer tokens directly.
        Returns the Vault client token — usable for Vault API calls only.
        For external service auth, retrieve the relevant secret and use it directly.
        """
        if not self._client.is_authenticated():
            self._authenticate()
        return self._client.token

    async def get_secret(self, secret_name: str) -> str:
        """
        Read a KV v2 secret. secret_name is the path within the KV mount.
        The secret must have a 'value' key, or override this method.
        """
        if not self._client.is_authenticated():
            self._authenticate()
        response = self._client.secrets.kv.v2.read_secret_version(
            path=secret_name,
            mount_point=self._kv_mount,
        )
        data: dict = response["data"]["data"]
        # Return 'value' key by convention; callers may access data directly via get_kv_data()
        return data.get("value", "")

    def get_kv_data(self, secret_name: str) -> dict:
        """Return the full KV v2 data dict for secrets with multiple keys."""
        if not self._client.is_authenticated():
            self._authenticate()
        response = self._client.secrets.kv.v2.read_secret_version(
            path=secret_name,
            mount_point=self._kv_mount,
        )
        return response["data"]["data"]

    @property
    def provider_name(self) -> str:
        return "vault"

