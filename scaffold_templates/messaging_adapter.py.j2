import aio_pika
import aio_pika.abc


{% if adapter.messaging.role in ("publisher", "both") %}
class {{ adapter.class_name }}Publisher(IEventPublisher):
    """{{ adapter.display_name }} event publisher (topic exchange)."""

    def __init__(self, connection: aio_pika.abc.AbstractConnection) -> None:
        self._connection = connection

    async def publish(self, topic: str, event: BaseEvent) -> None:
        channel = await self._connection.channel()
        exchange = await channel.declare_exchange(
            "{{ adapter.messaging.rabbitmq.exchange }}",
            aio_pika.ExchangeType.TOPIC,
            durable=True,
        )
        body = json.dumps(event.__dict__, default=str).encode()
        message = aio_pika.Message(
            body=body,
            content_type="application/json",
            delivery_mode=aio_pika.DeliveryMode.PERSISTENT,
        )
        await exchange.publish(message, routing_key=topic)
        logger.debug("Published %s to %s/%s", event.event_type, "{{ adapter.messaging.rabbitmq.exchange }}", topic)

    async def publish_batch(self, topic: str, events: list[BaseEvent]) -> None:
        for event in events:
            await self.publish(topic, event)
