{% elif adapter.messaging.broker == "azure_event_bus" %}
from azure.servicebus.aio import ServiceBusClient
from azure.servicebus import ServiceBusMessage, ServiceBusReceivedMessage


{% if adapter.messaging.role in ("publisher", "both") %}
class {{ adapter.class_name }}Publisher(IEventPublisher):
    """{{ adapter.display_name }} event publisher (Service Bus topics)."""

    def __init__(self, connection_string: str) -> None:
        self._connection_string = connection_string

    async def publish(self, topic: str, event: BaseEvent) -> None:
        async with ServiceBusClient.from_connection_string(self._connection_string) as client:
            sender = client.get_topic_sender(topic_name=topic)
            async with sender:
                body = json.dumps(event.__dict__, default=str)
                message = ServiceBusMessage(
                    body,
                    content_type="application/json",
                    subject=event.event_type,
                )
                await sender.send_messages(message)
                logger.debug("Published %s to topic=%s", event.event_type, topic)

    async def publish_batch(self, topic: str, events: list[BaseEvent]) -> None:
        async with ServiceBusClient.from_connection_string(self._connection_string) as client:
            sender = client.get_topic_sender(topic_name=topic)
            async with sender:
                batch = await sender.create_message_batch()
                for event in events:
                    body = json.dumps(event.__dict__, default=str)
                    batch.add_message(ServiceBusMessage(body, content_type="application/json"))
                await sender.send_messages(batch)
{% endif %}

{% if adapter.messaging.role in ("consumer", "both") %}
class {{ adapter.class_name }}Consumer:
    """{{ adapter.display_name }} event consumer (Service Bus subscriptions)."""

    def __init__(
        self,
        connection_string: str,
        handler_map: dict[str, object],
        topic: str = "{{ adapter.messaging.azure_event_bus.default_topic }}",
        subscription: str = "awa-agent-cortex",
    ) -> None:
        self._connection_string = connection_string
        self._handler_map = handler_map
        self._topic = topic
        self._subscription = subscription

    async def start(self) -> None:
        async with ServiceBusClient.from_connection_string(self._connection_string) as client:
            receiver = client.get_subscription_receiver(
                topic_name=self._topic,
                subscription_name=self._subscription,
            )
            async with receiver:
                async for message in receiver:
                    await self._dispatch(receiver, message)

    async def _dispatch(
        self,
        receiver: object,
        message: ServiceBusReceivedMessage,
    ) -> None:
        try:
            payload = json.loads(str(message))
            event_type = payload.get("event_type")
            handler = self._handler_map.get(event_type)
            if handler:
                await handler.safe_handle(payload)
                await receiver.complete_message(message)
            else:
                logger.warning("No handler for event_type=%s", event_type)
                await receiver.dead_letter_message(message, reason="NoHandler")
        except Exception:
            logger.exception("Failed to dispatch message")
            await receiver.abandon_message(message)
{% endif %}

{% elif adapter.messaging.broker == "aws_sqs" %}
import aiobotocore.session


{% if adapter.messaging.role in ("publisher", "both") %}
class {{ adapter.class_name }}Publisher(IEventPublisher):
    """{{ adapter.display_name }} event publisher (SQS)."""

    def __init__(self, queue_url: str, region: str) -> None:
        self._queue_url = queue_url
        self._region = region

    async def publish(self, topic: str, event: BaseEvent) -> None:
        session = aiobotocore.session.get_session()
        async with session.create_client("sqs", region_name=self._region) as client:
            body = json.dumps(event.__dict__, default=str)
            await client.send_message(
                QueueUrl=self._queue_url,
                MessageBody=body,
                MessageAttributes={
                    "event_type": {"StringValue": event.event_type, "DataType": "String"},
                    "topic":      {"StringValue": topic,            "DataType": "String"},
                },
            )

    async def publish_batch(self, topic: str, events: list[BaseEvent]) -> None:
        for event in events:
            await self.publish(topic, event)
{% endif %}

