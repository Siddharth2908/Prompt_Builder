{% if adapter.messaging.role in ("consumer", "both") %}
class {{ adapter.class_name }}Consumer:
    """{{ adapter.display_name }} event consumer."""

    def __init__(
        self,
        connection: aio_pika.abc.AbstractConnection,
        handler_map: dict[str, object],
    ) -> None:
        self._connection = connection
        self._handler_map = handler_map

    async def start(self) -> None:
        channel = await self._connection.channel()
        await channel.set_qos(prefetch_count=10)
        queue = await channel.declare_queue("awa.agent.cortex", durable=True)
        await queue.consume(self._dispatch)
        logger.info("{{ adapter.display_name }} consumer started")

    async def stop(self) -> None:
        await self._connection.close()

    async def _dispatch(self, message: aio_pika.abc.AbstractIncomingMessage) -> None:
        async with message.process():
            try:
                payload = json.loads(message.body)
                event_type = payload.get("event_type")
                handler = self._handler_map.get(event_type)
                if handler:
                    await handler.safe_handle(payload)
                else:
                    logger.warning("No handler for event_type=%s", event_type)
            except Exception:
                logger.exception("Failed to dispatch message")
                # message will be nacked and requeued by aio_pika on exception
